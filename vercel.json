{
  "version": 2,
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/buildtech/easyfood/(.*)",
      "destination": "https://restaurante-lyart.vercel.app/$1"
    },
    {
      "source": "/buildtech/easyfood",
      "destination": "https://restaurante-lyart.vercel.app/"
    },
    {
      "source": "/buildtech/(.*)",
      "destination": "https://wg-build-tech.vercel.app/$1"
    },
    {
      "source": "/buildtech",
      "destination": "https://wg-build-tech.vercel.app/"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/easylocker",
      "destination": "/easylocker/index.html"
    },
    {
      "source": "/sobre",
      "destination": "/sobre/index.html"
    },
    {
      "source": "/processo",
      "destination": "/processo/index.html"
    },
    {
      "source": "/projetos",
      "destination": "/projetos/index.html"
    },
    {
      "source": "/store",
      "destination": "/store/index.html"
    },
    {
      "source": "/arquitetura",
      "destination": "/arquitetura/index.html"
    },
    {
      "source": "/engenharia",
      "destination": "/engenharia/index.html"
    },
    {
      "source": "/marcenaria",
      "destination": "/marcenaria/index.html"
    },
    {
      "source": "/solicite-proposta",
      "destination": "/solicite-proposta/index.html"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
