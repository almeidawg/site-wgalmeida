# =====================================================
# Variáveis de Ambiente - WG Almeida Site
# =====================================================

# Supabase (já configurado)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=sua-chave-anon

# =====================================================
# Cloudinary - Upload e Transformações de Imagem
# https://cloudinary.com/console
# =====================================================
VITE_CLOUDINARY_CLOUD_NAME=seu-cloud-name
VITE_CLOUDINARY_API_KEY=sua-api-key
VITE_CLOUDINARY_UPLOAD_PRESET=wg_unsigned

# Nota: Para usar Generative AI do Cloudinary, você precisa
# de um plano que inclua esses recursos (não disponível no free)

# =====================================================
# Stability AI - Geração de Imagens Fotorrealistas
# https://platform.stability.ai/account/keys
# Configurar no servidor/Vercel (nao expor no navegador)
# =====================================================
STABILITY_API_KEY=sua-api-key-stability

# Preços aproximados (jan/2025):
# - SDXL 1.0: $0.002-0.006 por imagem
# - Image-to-Image: similar

# =====================================================
# IA (OpenAI/Claude) - usar chaves privadas no servidor (Vercel)
# =====================================================
# Configurar em: Vercel Project -> Settings -> Environment Variables
# NÃO usar VITE_* para chaves sensíveis de OpenAI/Claude.
OPENAI_API_KEY=sua-api-key-openai
CLAUDE_API_KEY=sua-api-key-claude
CLAUDE_MODEL=claude-3-5-sonnet-latest
CLAUDE_MODEL=claude-3-5-sonnet-latest
# Opcional: sobrescrever assistant da Liz
OPENAI_LIZ_ASSISTANT_ID=asst_xxxxxxxxxxxxxxxxxxxxxxxx

# Alternativas de IA (opcional)
# =====================================================
# Replicate - Múltiplos modelos
# https://replicate.com/account
# VITE_REPLICATE_API_TOKEN=sua-token

# =====================================================
# Google Reviews (opcional)
# =====================================================
# Endpoint público para reviews (se existir):
# VITE_GOOGLE_REVIEWS_URL=https://seu-endpoint.com/google-reviews
#
# Para função server-side (ex.: /api/google-reviews no Vercel):
# GOOGLE_PLACE_ID=seu_place_id
# GOOGLE_PLACES_API_KEY=sua_chave_server_side

# =====================================================
# Unsplash (opcional, para fila editorial automatizada e moodboard)
# https://unsplash.com/developers
# Nota: a API do Unsplash exige hotlinking e rastreio de download.
# O blog pode usar URLs diretas de `images.unsplash.com` com credito.
# Use a collection abaixo para puxar o acervo editorial curado.
# Nao commitar chaves reais.
# =====================================================
UNSPLASH_ACCESS_KEY=sua-access-key-unsplash
VITE_UNSPLASH_ACCESS_KEY=sua-access-key-unsplash
UNSPLASH_COLLECTION_REF=yU-ii4hFjlg
VITE_UNSPLASH_UTM_SOURCE=wg-almeida-blog

# Google Custom Search (opcional, para source `image_search`
# no Upload Widget do Cloudinary no admin editorial)
VITE_GOOGLE_IMAGE_SEARCH_API_KEY=sua-google-custom-search-api-key

