{
  "name": "grupo-wg-almeida",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "vite --host :: --port 3000",
    "build": "npm run seo:og && vite build && npm run seo:routes",
    "build:local": "npm run seo:og && vite build --outDir dist-local --emptyOutDir false --clearScreen false && npm run seo:routes:local",
    "analyze": "ANALYZE=true vite build",
    "seo:og": "node ./build-seo-og.mjs",
    "seo:routes:local": "node ./build-seo-routes.mjs dist-local",
    "seo:routes": "node ./build-seo-routes.mjs dist",
    "seo:audit": "node ./tools/seo-audit.mjs",
    "seo:validate:dist": "node ./tools/seo-validate-dist.mjs dist",
    "seo:validate": "npm run seo:audit && npm run seo:validate:dist",
    "seo:validate:fresh": "npm run seo:audit && npm run build && npm run seo:validate:dist",
    "preview": "vite preview --host :: --port 3000",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "perf:seo": "powershell -ExecutionPolicy Bypass -File ./test-seo.ps1",
    "perf:assets": "node ./tools/perf-assets-report.mjs",
    "perf:images": "node ./tools/recompress-critical-images.mjs dist",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.3.1",
    "@radix-ui/react-alert-dialog": "^1.0.5",
